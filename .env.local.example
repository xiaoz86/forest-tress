# Supabase Configuration
# Get these from your Supabase project settings: https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# New Member Email Notification (optional)
# If RESEND_API_KEY is not set, email notifications are silently skipped.
# Sign up at https://resend.com to get a free API key.
RESEND_API_KEY=

# Comma-separated list of recipients. Defaults to 1826741794@qq.com if unset.
# Example: NOTIFY_EMAILS=host1@qq.com,host2@gmail.com
NOTIFY_EMAILS=

# Sender identity. Must be a verified domain in Resend, OR use the default
# 'onboarding@resend.dev' (only works for sending to yourself in the Resend account email).
# After verifying nearby-forest.club in Resend, switch to e.g.:
# NOTIFY_FROM=附近森林 <noreply@nearby-forest.club>
NOTIFY_FROM=
